{
  "name": "@delta-and-beta/electron-datatable",
  "version": "0.13.1",
  "description": "A feature-rich, composable React data table with multi-level grouping, attachments, search, and column management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js",
      "require": "./dist/tailwind.cjs"
    },
    "./matching": {
      "types": "./dist/matching.d.ts",
      "import": "./dist/matching.js",
      "require": "./dist/matching.cjs"
    },
    "./sync": {
      "types": "./dist/sync.d.ts",
      "import": "./dist/sync.js",
      "require": "./dist/sync.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./themes/dark.css": "./dist/themes/dark.css",
    "./themes/light.css": "./dist/themes/light.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && tailwindcss -i src/styles-input.css -o dist/styles.css -c tailwind.build.config.ts --minify && mkdir -p dist/themes && cp src/themes/*.css dist/themes/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "lucide-react": "^0.468.0",
    "tailwind-merge": "^2.6.0"
  },
  "keywords": [
    "react",
    "table",
    "electron-datatable",
    "data-table",
    "group-by",
    "grouping",
    "tailwind",
    "compound-component"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/delta-and-beta/electron-datatable.git"
  }
}
